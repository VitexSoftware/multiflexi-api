#!/usr/bin/make -f
# You must remove unused comment lines for the released package.
#export DH_VERBOSE = 1
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed
export DB_CONNECTION = dummy
export DB_HOST = dummy
export DB_PORT = dummy
export DB_DATABASE = dummy
export DB_USERNAME = dummy
export DB_PASSWORD = dummy

%:
	dh $@

override_dh_auto_build:
	COMPOSER_HOME=/tmp/composer-cache COMPOSER_ALLOW_SUPERUSER=1 \
		composer install --no-dev --no-interaction --working-dir=$(CURDIR)

override_dh_auto_install:

override_dh_install:
	dh_install
	# Patch autoload chain in the installed index.php
	sed -i "/require_once __DIR__/crequire_once '/usr/share/php/multiflexi-web/autoload.php';" \
		debian/multiflexi-api/usr/share/multiflexi-server/api/index.php
	sed -i "\|require_once '/usr/share/php/multiflexi-web/autoload.php';|a require_once '/usr/share/php/MultiFlexiApi/autoload.php';" \
		debian/multiflexi-api/usr/share/multiflexi-server/api/index.php
	sed -i "\|require_once '/usr/share/php/MultiFlexiApi/autoload.php';|a require_once '/var/lib/composer/multiflexi/autoload.php';" \
		debian/multiflexi-api/usr/share/multiflexi-server/api/index.php
	sed -i "/loadConfig/c\\\\\Ease\\\\Shared::singleton()->loadConfig('/etc/multiflexi/multiflexi.env', true);" \
		debian/multiflexi-api/usr/share/multiflexi-server/api/index.php
	# Install Composer vendor tree and create autoload.php shim
	install -d debian/multiflexi-api/var/lib/composer/multiflexi
	cp -a $(CURDIR)/vendor debian/multiflexi-api/var/lib/composer/multiflexi/
	printf '<?php\nrequire_once __DIR__ . '"'"'/vendor/autoload.php'"'"';\n' \
		> debian/multiflexi-api/var/lib/composer/multiflexi/autoload.php
